{
  "name": "hopr-video",
  "version": "1.0.0",
  "description": "Remotion product video for Hopr — clean, modern 3D promo (hook + demo).",
  "private": true,
  "scripts": {
    "dev": "remotion studio",
    "studio": "remotion studio",
