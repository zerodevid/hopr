    "still": "remotion still HoprPromo out/poster.png --frame=90",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.482",
    "@remotion/google-fonts": "4.0.482",
    "@remotion/transitions": "^4.0.482",
